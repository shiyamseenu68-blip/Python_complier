# Supabase Configuration (Required for snippets and history features)
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend URL (Optional - for deployed backend)
# Leave empty for local development (uses localhost:8000)
# Set to deployed backend URL for Vercel deployment (e.g., https://your-backend.onrender.com)
VITE_BACKEND_URL=
